# === EIV Core environment configuration ===
# The service runs with zero configuration (reference implementations).
# Each variable below independently upgrades one component to its production
# implementation. Copy to .env (or export) to use.

# --- ChainAdapter: live trace reconstruction (RpcChainAdapter) ---
# Setting RPC_URL switches the trace source from bundled fixtures to a live
# EVM node (receipt + logs + post-execution allowance reads).
# RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- AttestationSink: ERC-8004 ValidationRegistry write (OnChainAttestationSink) ---
# Both values below (plus RPC_URL) enable on-chain attestation.
# Registry address from contracts/DEPLOYMENTS.md (or your own deployment via
# contracts/deploy_registry.py).
# EIV_VALIDATION_REGISTRY_ADDRESS=0x...
# Private key of the attester account — never commit a real key.
# ATTESTER_PRIVATE_KEY=your_private_key_here
# Sign the attestation transaction but do not broadcast it (rehearsal mode).
# EIV_ATTEST_DRY_RUN=1
# Optional responseURI prefix recorded on-chain (e.g. a public /validations URL).
# EIV_RESPONSE_URI_BASE=https://example.org/validations

# --- EIP-712 verification (Eip712Verifier — enabled by default) ---
# Domain chain id for the typed-data digest (default: 11155111, Sepolia).
# CHAIN_ID=11155111
# Reject unsigned intents outright (default: accept but mark auth.verified=false).
# EIV_REQUIRE_SIGNATURE=1
